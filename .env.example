# ===========================================
# Production Environment Variables
# Copy this file to .env and fill in real values
# ===========================================

# Database (PostgreSQL) - REQUIRED
# Local VPS example:
DATABASE_URL="postgresql://circucity:YOUR_STRONG_PASSWORD@localhost:5432/circucity_ai?schema=public"
# Or external (Neon, Supabase, etc.):
# DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/circucity_ai?sslmode=require"

# JWT Secret - REQUIRED (generate strong random string, min 32 chars)
JWT_SECRET="REPLACE_WITH_64_CHAR_RANDOM_SECRET_FROM_openssl_rand_base64_48"

# Application URL - REQUIRED for production
NEXT_PUBLIC_URL="https://chatbot.circucity.se"

# App Branding
NEXT_PUBLIC_APP_NAME="CircuitCity AI"
NEXT_PUBLIC_APP_DESCRIPTION="Personalized AI Customer Support for E-commerce"

# Stripe - REQUIRED for paid plans
STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (create these in your Stripe Dashboard)
# Starter = Free (price_xxx for $0)
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_GROWTH="price_..."
STRIPE_PRICE_ENTERPRISE="price_..."

# Optional: If using Redis or other services later
# REDIS_URL=""

# Node
NODE_ENV="production"
PORT=3000